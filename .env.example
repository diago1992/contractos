# ==============================================================================
# ContractOS — Environment Variables
# ==============================================================================

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — AI extraction pipeline (required)
ANTHROPIC_API_KEY=

# OpenAI — embeddings for semantic search (optional — semantic search disabled without this)
OPENAI_API_KEY=

# App URL — used for Slack deep links (defaults to http://localhost:3000)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron secret — bearer token to protect cron endpoints
CRON_SECRET=

# Slack integration (optional — Slack features disabled without these)
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
SLACK_SIGNING_SECRET=

# NetSuite GL integration (optional — vendor sync disabled without these)
NETSUITE_ACCOUNT_ID=
NETSUITE_CONSUMER_KEY=
NETSUITE_CONSUMER_SECRET=
NETSUITE_TOKEN_ID=
NETSUITE_TOKEN_SECRET=
